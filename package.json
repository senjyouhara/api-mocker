{
  "name": "api-mocker",
  "private": true,
  "version": "0.1.0",
  "description": "基于 `Tauri + Vue 3` 的本地 API Mock 与请求调试工具，面向前端联调、接口演示和本地自测工具",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.{vue,js,jsx,cjs,mjs,ts,tsx,json,css,scss,less,html,md}\"",
    "prepare": "husky install",
    "tauri": "tauri",
    "lint-staged": "lint-staged"
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{vue,js,jsx,cjs,mjs,ts,tsx,html}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,json,css,scss,less}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2.2.7",
    "@vueuse/core": "^14.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "lodash-es": "^4.17.21",
    "lucide-vue-next": "^0.563.0",
    "mockjs": "^1.1.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.2",
    "pinia-plugin-persistedstate": "^4.2.0",
    "reka-ui": "^2.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tauri-apps/cli": "^2.5.3",
    "@types/mockjs": "^1.0.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "~9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.1.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.4",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.53.1",
    "unplugin-auto-import": "^19.2.0",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.0.3",
    "vue-tsc": "^2.2.10"
  }
}
