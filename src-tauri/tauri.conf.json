{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "apiMocker",
  "version": "0.1.0",
  "identifier": "com.alice.apiMocker",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "apiMocker",
        "width": 1000,
        "height": 750,
        "minWidth": 1000,
        "minHeight": 750,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
